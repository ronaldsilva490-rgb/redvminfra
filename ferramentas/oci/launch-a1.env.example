# Copy to launch-a1.env on the VM and fill with your Oracle Cloud values.

OCI_BIN=oci
OCI_PROFILE=DEFAULT
OCI_CONFIG_FILE=/root/.oci/config

COMPARTMENT_ID=ocid1.compartment.oc1..CHANGE_ME
AVAILABILITY_DOMAIN=CHANGE_ME:SA-SAOPAULO-1-AD-1
SUBNET_ID=ocid1.subnet.oc1.sa-saopaulo-1.CHANGE_ME
IMAGE_ID=ocid1.image.oc1.sa-saopaulo-1.CHANGE_ME
SSH_KEY_FILE=/root/.ssh/id_rsa.pub

DISPLAY_NAME=red-a1-free
OCPUS=4
MEMORY_GB=24
BOOT_VOLUME_GB=200
ASSIGN_PUBLIC_IP=true
WAIT_SECONDS=60
OCI_REQUEST_TIMEOUT_SECONDS=180
OCI_RATE_LIMIT_WAIT_SECONDS=300
