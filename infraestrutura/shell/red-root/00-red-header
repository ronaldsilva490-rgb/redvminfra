#!/usr/bin/env bash
set -u

export LANG=pt_BR.UTF-8
export LANGUAGE=pt_BR:pt

RED=$'\033[38;2;255;0;0m'
GREEN=$'\033[38;2;0;255;120m'
WHITE=$'\033[1;37m'
RESET=$'\033[0m'
BOX_INNER=52
FRAME_INNER=$((BOX_INNER + 2))

repeat_char() {
    local char="$1"
    local count="$2"
    local out=""
    local i
    for ((i=0; i<count; i++)); do
        out+="$char"
    done
    printf '%s' "$out"
}

get_ip() {
    hostname -I 2>/dev/null | awk '{print $1}'
}

format_uptime() {
    uptime -p 2>/dev/null \
        | sed 's/^up //' \
        | sed 's/, /, /g' \
        | sed 's/ hours\?/ horas/g' \
        | sed 's/ hour / hora /g' \
        | sed 's/ minutes\?/ minutos/g' \
        | sed 's/ minute / minuto /g' \
        | sed 's/ days\?/ dias/g' \
        | sed 's/ day / dia /g' \
        | sed 's/ weeks\?/ semanas/g' \
        | sed 's/ week / semana /g'
}

clear_screen() {
    if [ -t 1 ] && [ -n "${TERM:-}" ] && command -v clear >/dev/null 2>&1; then
        clear
    fi
}

status_color_from_percent() {
    local pct="$1"
    if [ -z "$pct" ]; then
        printf '%s' "$WHITE"
    elif [ "$pct" -ge 85 ]; then
        printf '%s' "$RED"
    else
        printf '%s' "$GREEN"
    fi
}

border() {
    local fill
    fill="$(repeat_char 'в•ђ' "${FRAME_INNER}")"
    printf '%b\n' "${RED}в•”${fill}в•—${RESET}"
}

divider() {
    local fill
    fill="$(repeat_char 'в•ђ' "${FRAME_INNER}")"
    printf '%b\n' "${RED}в• ${fill}в•Ј${RESET}"
}

footer() {
    local fill
    fill="$(repeat_char 'в•ђ' "${FRAME_INNER}")"
    printf '%b\n' "${RED}в•љ${fill}в•ќ${RESET}"
}

line() {
    local content="$1"
    local plain visible pad
    plain="$(printf '%b' "$content" | sed -r 's/\x1B\[[0-9;]*[A-Za-z]//g')"
    visible=$(printf '%s' "$plain" | awk '{print length}')
    pad=$((76 - visible))
    if [ "$pad" -lt 0 ]; then
        pad=0
    fi
    printf '%b%b%*s%b\n' "${RED}в•‘ ${RESET}" "$content" "$pad" '' "${RED} в•‘${RESET}"
}

center_line() {
    local content="$1"
    local plain visible left right
    plain="$(printf '%b' "$content" | sed -r 's/\x1B\[[0-9;]*[A-Za-z]//g')"
    visible=$(printf '%s' "$plain" | awk '{print length}')
    if [ "$visible" -gt "$BOX_INNER" ]; then
        visible="$BOX_INNER"
    fi
    left=$(( (BOX_INNER - visible) / 2 ))
    if [ "$left" -lt 0 ]; then
        left=0
    fi
    right=$(( BOX_INNER - visible - left ))
    if [ "$right" -lt 0 ]; then
        right=0
    fi
    printf '%b%*s%b%*s%b\n' "${RED}в•‘ ${RESET}" "$left" '' "$content" "$right" '' "${RED} в•‘${RESET}"
}

service_text() {
    local svc="$1"
    if systemctl is-active --quiet "$svc" 2>/dev/null; then
        printf '%sATIVO%s' "$GREEN" "$RESET"
    else
        printf '%sINATIVO%s' "$RED" "$RESET"
    fi
}

SYSTEM_STATE="$(systemctl is-system-running 2>/dev/null || true)"
LOAD="$(awk '{print $1}' /proc/loadavg 2>/dev/null)"
UPTIME_TEXT="$(format_uptime)"
MEMORY_INFO="$(free -m | awk 'NR==2 {printf "%s/%s MB (%d%%)", $3, $2, int(($3/$2)*100)}')"
MEMORY_PCT="$(free -m | awk 'NR==2 {printf "%d", int(($3/$2)*100)}')"
DISK_INFO="$(df -h / | awk 'NR==2 {printf "%s/%s (%s)", $3, $2, $5}')"
DISK_PCT="$(df -h / | awk 'NR==2 {print $5}' | tr -d '%')"
IP_ADDR="$(get_ip)"
SSH_STATE="$(service_text ssh)"
ZOMBIES="$(ps -eo stat= | awk '$1 ~ /^Z/ {count++} END {print count+0}')"
UPDATES="N/D"

if command -v apt >/dev/null 2>&1; then
    UPDATES="$(apt list --upgradable 2>/dev/null | tail -n +2 | wc -l)"
fi

if [ "$SYSTEM_STATE" = "running" ]; then
    SYSTEM_STATE_FMT="${GREEN}OPERACIONAL${RESET}"
else
    SYSTEM_STATE_FMT="${RED}${SYSTEM_STATE:-desconhecido}${RESET}"
fi

MEM_COLOR="$(status_color_from_percent "$MEMORY_PCT")"
DISK_COLOR="$(status_color_from_percent "$DISK_PCT")"

if [ "$ZOMBIES" -gt 0 ]; then
    ZOMBIE_FMT="${RED}${ZOMBIES}${RESET}"
else
    ZOMBIE_FMT="${GREEN}0${RESET}"
fi

if [ "$UPDATES" = "N/D" ]; then
    UPDATES_FMT="${WHITE}N/D${RESET}"
elif [ "$UPDATES" -gt 0 ]; then
    UPDATES_FMT="${RED}${UPDATES}${RESET}"
else
    UPDATES_FMT="${GREEN}0${RESET}"
fi

clear_screen
border
line ""
center_line "${RED} ____  _____ ____ ${RESET}"
center_line "${RED}|  _ \\| ____|  _ \\\\${RESET}"
center_line "${RED}| |_) |  _| | | | |${RESET}"
center_line "${RED}|  _ <| |___| |_| |${RESET}"
center_line "${RED}|_| \\_\\\\_____|____/ ${RESET}"
line ""
divider
line "${WHITE}Sistema${RESET}    : ${SYSTEM_STATE_FMT}"
line "${WHITE}Hostname${RESET}   : ${WHITE}$(hostname)${RESET}"
line "${WHITE}Kernel${RESET}     : ${WHITE}$(uname -r | cut -d'-' -f1)${RESET}"
line "${WHITE}Uptime${RESET}     : ${GREEN}${UPTIME_TEXT:-indisponivel}${RESET}"
line "${WHITE}Carga${RESET}      : ${WHITE}${LOAD:-indisponivel}${RESET}"
line "${WHITE}Memoria${RESET}    : ${MEM_COLOR}${MEMORY_INFO}${RESET}"
line "${WHITE}Disco raiz${RESET} : ${DISK_COLOR}${DISK_INFO}${RESET}"
line "${WHITE}IPv4${RESET}       : ${WHITE}${IP_ADDR:-indisponivel}${RESET}"
line "${WHITE}SSH${RESET}        : ${SSH_STATE}"
line "${WHITE}Zumbis${RESET}     : ${ZOMBIE_FMT}"
line "${WHITE}Updates${RESET}    : ${UPDATES_FMT}"
divider
line "${WHITE}Comandos uteis${RESET}"
line "${WHITE}painel${RESET} -> painel RED ao vivo"
line "${WHITE}motd${RESET}   -> redesenha o banner"
footer
printf '\n'
