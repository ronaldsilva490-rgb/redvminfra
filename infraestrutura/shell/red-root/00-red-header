#!/usr/bin/env bash
set -u

export LANG=pt_BR.UTF-8
export LANGUAGE=pt_BR:pt

RED=$'\033[38;2;255;0;0m'
GREEN=$'\033[38;2;0;255;120m'
WHITE=$'\033[1;37m'
RESET=$'\033[0m'

get_ip() {
    hostname -I 2>/dev/null | awk '{print $1}'
}

format_uptime() {
    uptime -p 2>/dev/null \
        | sed 's/^up //' \
        | sed 's/, /, /g' \
        | sed 's/ hours\?/ horas/g' \
        | sed 's/ hour / hora /g' \
        | sed 's/ minutes\?/ minutos/g' \
        | sed 's/ minute / minuto /g' \
        | sed 's/ days\?/ dias/g' \
        | sed 's/ day / dia /g' \
        | sed 's/ weeks\?/ semanas/g' \
        | sed 's/ week / semana /g'
}

clear_screen() {
    if [ -t 1 ] && [ -n "${TERM:-}" ] && command -v clear >/dev/null 2>&1; then
        clear
    fi
}

status_color_from_percent() {
    local pct="$1"
    if [ -z "$pct" ]; then
        printf '%s' "$WHITE"
    elif [ "$pct" -ge 85 ]; then
        printf '%s' "$RED"
    else
        printf '%s' "$GREEN"
    fi
}

separator() {
    printf '%b\n' "${RED}------------------------------------------------------------${RESET}"
}

print_kv() {
    local label="$1"
    local value="$2"
    printf '%b%-11s%b : %b\n' "${WHITE}" "$label" "${RESET}" "$value"
}

service_text() {
    local svc="$1"
    if systemctl is-active --quiet "$svc" 2>/dev/null; then
        printf '%sATIVO%s' "$GREEN" "$RESET"
    else
        printf '%sINATIVO%s' "$RED" "$RESET"
    fi
}

SYSTEM_STATE="$(systemctl is-system-running 2>/dev/null || true)"
LOAD="$(awk '{print $1}' /proc/loadavg 2>/dev/null)"
UPTIME_TEXT="$(format_uptime)"
MEMORY_INFO="$(free -m | awk 'NR==2 {printf "%s/%s MB (%d%%)", $3, $2, int(($3/$2)*100)}')"
MEMORY_PCT="$(free -m | awk 'NR==2 {printf "%d", int(($3/$2)*100)}')"
DISK_INFO="$(df -h / | awk 'NR==2 {printf "%s/%s (%s)", $3, $2, $5}')"
DISK_PCT="$(df -h / | awk 'NR==2 {print $5}' | tr -d '%')"
IP_ADDR="$(get_ip)"
SSH_STATE="$(service_text ssh)"
ZOMBIES="$(ps -eo stat= | awk '$1 ~ /^Z/ {count++} END {print count+0}')"
UPDATES="N/D"

if command -v apt >/dev/null 2>&1; then
    UPDATES="$(apt list --upgradable 2>/dev/null | tail -n +2 | wc -l)"
fi

if [ "$SYSTEM_STATE" = "running" ]; then
    SYSTEM_STATE_FMT="${GREEN}OPERACIONAL${RESET}"
else
    SYSTEM_STATE_FMT="${RED}${SYSTEM_STATE:-desconhecido}${RESET}"
fi

MEM_COLOR="$(status_color_from_percent "$MEMORY_PCT")"
DISK_COLOR="$(status_color_from_percent "$DISK_PCT")"

if [ "$ZOMBIES" -gt 0 ]; then
    ZOMBIE_FMT="${RED}${ZOMBIES}${RESET}"
else
    ZOMBIE_FMT="${GREEN}0${RESET}"
fi

if [ "$UPDATES" = "N/D" ]; then
    UPDATES_FMT="${WHITE}N/D${RESET}"
elif [ "$UPDATES" -gt 0 ]; then
    UPDATES_FMT="${RED}${UPDATES}${RESET}"
else
    UPDATES_FMT="${GREEN}0${RESET}"
fi

clear_screen
printf '\n'
printf '%b\n' "${RED}██████╗ ███████╗██████╗${RESET}"
printf '%b\n' "${RED}██╔══██╗██╔════╝██╔══██╗${RESET}"
printf '%b\n' "${RED}██████╔╝█████╗  ██║  ██║${RESET}"
printf '%b\n' "${RED}██╔══██╗██╔══╝  ██║  ██║${RESET}"
printf '%b\n' "${RED}██║  ██║███████╗██████╔╝${RESET}"
printf '%b\n' "${RED}╚═╝  ╚═╝╚══════╝╚═════╝ ${RESET}"
printf '\n'
separator
print_kv "Sistema" "${SYSTEM_STATE_FMT}"
print_kv "Hostname" "${WHITE}$(hostname)${RESET}"
print_kv "Kernel" "${WHITE}$(uname -r | cut -d'-' -f1)${RESET}"
print_kv "Uptime" "${GREEN}${UPTIME_TEXT:-indisponivel}${RESET}"
print_kv "Carga" "${WHITE}${LOAD:-indisponivel}${RESET}"
print_kv "Memoria" "${MEM_COLOR}${MEMORY_INFO}${RESET}"
print_kv "Disco raiz" "${DISK_COLOR}${DISK_INFO}${RESET}"
print_kv "IPv4" "${WHITE}${IP_ADDR:-indisponivel}${RESET}"
print_kv "SSH" "${SSH_STATE}"
print_kv "Zumbis" "${ZOMBIE_FMT}"
print_kv "Updates" "${UPDATES_FMT}"
separator
printf '%b\n' "${WHITE}Comandos uteis${RESET}"
printf '%b\n' "${WHITE}painel${RESET} -> painel RED ao vivo"
printf '%b\n' "${WHITE}motd${RESET}   -> redesenha o banner"
separator
printf '\n'
