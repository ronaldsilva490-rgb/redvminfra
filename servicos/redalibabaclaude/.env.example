REDALIBABACLAUDE_HOST=0.0.0.0
REDALIBABACLAUDE_PORT=5052
REDALIBABACLAUDE_SG_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
REDALIBABACLAUDE_US_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
REDALIBABACLAUDE_SG_API_KEY=
REDALIBABACLAUDE_US_API_KEY=
# pools comma-separated; o helper /usr/local/bin/alibaba gerencia isso automaticamente
REDALIBABACLAUDE_SG_API_KEYS=
REDALIBABACLAUDE_US_API_KEYS=
REDALIBABACLAUDE_REQUIRE_AUTH=1
REDALIBABACLAUDE_AUTH_TOKENS=red
REDALIBABACLAUDE_DEFAULT_MODEL=qwen3.6-plus
REDALIBABACLAUDE_STREAM_CHUNK_SIZE=1
REDALIBABACLAUDE_SSE_HEARTBEAT_SECONDS=12
REDALIBABACLAUDE_SSE_HEARTBEAT_QUEUE_SIZE=2048
REDALIBABACLAUDE_CONNECT_TIMEOUT=20
REDALIBABACLAUDE_READ_TIMEOUT=360
REDALIBABACLAUDE_MAX_OUTPUT_TOKENS=8192
REDALIBABACLAUDE_DIRECT_PROTOCOL_MODE=1
REDALIBABACLAUDE_WEBSEARCH_FALLBACK_ENABLED=0
REDALIBABACLAUDE_WEBSEARCH_FALLBACK_URL=http://127.0.0.1:8088/search
REDALIBABACLAUDE_WEBSEARCH_FALLBACK_MAX_RESULTS=5
REDALIBABACLAUDE_WEBSEARCH_FALLBACK_MAX_QUERIES=3
REDALIBABACLAUDE_WEBSEARCH_FALLBACK_TIMEOUT=8
REDALIBABACLAUDE_WEBSEARCH_FALLBACK_LANGUAGE=pt-BR
REDALIBABACLAUDE_WEBSEARCH_INTERNAL_MAX_ROUNDS=0
REDALIBABACLAUDE_WEBSEARCH_INTERNALIZE_STREAM_REQUESTS=0
REDALIBABACLAUDE_LIVE_EXTERNAL_TOOL_STREAMING=1
REDALIBABACLAUDE_TOOL_REPAIR_MAX_ROUNDS=0
REDALIBABACLAUDE_EMPTY_OUTPUT_REPAIR_MAX_ROUNDS=0
REDALIBABACLAUDE_TODO_ONLY_REPAIR_MAX_ROUNDS=0
REDALIBABACLAUDE_WORKSPACE_ACTION_REPAIR_MAX_ROUNDS=0
REDALIBABACLAUDE_DATA_DIR=/var/lib/redalibabaclaude
REDALIBABACLAUDE_FILES_DIR=/var/lib/redalibabaclaude/files
REDALIBABACLAUDE_FILE_UPLOAD_MAX_BYTES=33554432
REDALIBABACLAUDE_TOKEN_METRICS_ENABLED=1
REDALIBABACLAUDE_TOKEN_METRICS_DB=/var/lib/redalibabaclaude/token_usage.sqlite3
REDALIBABACLAUDE_TOKEN_METRICS_QUEUE_SIZE=10000
REDALIBABACLAUDE_TOKEN_METRICS_RECENT_LIMIT=80
REDALIBABACLAUDE_SG_SMOKE_MODEL=qwen3.6-plus
REDALIBABACLAUDE_US_SMOKE_MODEL=qwen3-coder-plus
REDALIBABACLAUDE_SG_SMOKE_CANDIDATES=qwen3.6-plus qwen-coder-plus qwen3-coder-next qwen3.6-max-preview
REDALIBABACLAUDE_US_SMOKE_CANDIDATES=deepseek-v4-flash qwen3-coder-plus deepseek-v4-pro kimi-k2.5
REDALIBABACLAUDE_KEY_SMOKE_TIMEOUT=7
REDALIBABACLAUDE_TOKEN_SAFETY_MARGIN=4096
REDALIBABACLAUDE_MIN_COMPLETION_TOKENS=256
REDALIBABACLAUDE_MAX_CONTEXT_RETRIES=5
REDALIBABACLAUDE_CONTEXT_RETRY_MARGIN_STEP=2048
REDALIBABACLAUDE_RATE_LIMIT_MIN_INTERVAL_SECONDS=1
REDALIBABACLAUDE_RATE_LIMIT_COOLDOWN_SECONDS=12
REDALIBABACLAUDE_RATE_LIMIT_COOLDOWN_STEP_SECONDS=4
REDALIBABACLAUDE_RATE_LIMIT_MAX_COOLDOWN_SECONDS=45
REDALIBABACLAUDE_MAX_429_RETRIES=6
REDALIBABACLAUDE_SERVER_ERROR_COOLDOWN_SECONDS=4
REDALIBABACLAUDE_MAX_5XX_RETRIES=4
REDALIBABACLAUDE_EXPERIMENTAL_THINKING_BLOCKS=1
REDALIBABACLAUDE_FAKE_THINKING_SIGNATURE_PREFIX=redalibaba
REDALIBABACLAUDE_FORCE_ANTHROPIC_THINKING=0
REDALIBABACLAUDE_TLS_CERT=/etc/letsencrypt/live/redsystems.ddns.net/fullchain.pem
REDALIBABACLAUDE_TLS_KEY=/etc/letsencrypt/live/redsystems.ddns.net/privkey.pem
