REDIA_HOST=0.0.0.0
REDIA_PORT=3099
REDIA_DATA_DIR=./data
REDIA_DB_PATH=./data/redia.sqlite
REDIA_ADMIN_TOKEN=change-me

# RED Systems Ollama-compatible proxy.
# Na VM unica, prefira o endpoint local para evitar hairpin/ufw e manter baixa latencia.
REDIA_PROXY_URL=http://127.0.0.1:8080
REDIA_DEFAULT_MODEL=
REDIA_VISION_MODEL=
REDIA_LEARNING_MODEL=
REDIA_PROACTIVE_MODEL=
REDIA_IMAGE_PROMPT_MODEL=
REDIA_IMAGE_WORKER_TOKEN=

# Optional STT provider. The proxy currently handles text/vision, not audio transcription.
REDIA_STT_PROVIDER=groq
GROQ_API_KEY=
OPENAI_API_KEY=

# Edge TTS runs through Python edge-tts + ffmpeg.
REDIA_TTS_ENABLED=true
REDIA_TTS_AUDIO_PROBABILITY=0.12
REDIA_TTS_VOICE=pt-BR-FranciscaNeural
REDIA_TTS_RATE=-5%
REDIA_TTS_PITCH=+0Hz
REDIA_TTS_VOLUME=+0%
