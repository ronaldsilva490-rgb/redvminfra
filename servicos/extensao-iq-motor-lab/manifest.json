{
  "manifest_version": 3,
  "name": "RED IQ Motor Lab",
  "description": "Motor secundario de experimentacao remota para a IQ demo, controlado por JSON via bridge.",
  "version": "0.0.6",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://iqoption.com/*",
    "https://*.iqoption.com/*",
    "http://redsystems.ddns.net/iq-bridge/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "RED IQ Motor Lab"
  },
  "content_scripts": [
    {
      "matches": [
        "https://iqoption.com/*",
        "https://*.iqoption.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/injected-bridge.js"
      ],
      "matches": [
        "https://iqoption.com/*",
        "https://*.iqoption.com/*"
      ]
    }
  ]
}


