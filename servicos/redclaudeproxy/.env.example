# RED Claude Proxy
# Ponte Anthropic/Claude baseada no RED Proxy Pro, usando o proxy normal como upstream.

REDCLAUDEPROXY_HOST=127.0.0.1
REDCLAUDEPROXY_PORT=8096
REDCLAUDEPROXY_UPSTREAM_BASE_URL=http://127.0.0.1:8080/v1

# Token usado para chamar o proxy normal internamente.
# Tambem aceita REDCLAUDEPROXY_KEYS="normal:red".
REDCLAUDEPROXY_UPSTREAM_TOKEN=red
REDCLAUDEPROXY_KEYS="normal:red"

# Token exigido dos clientes externos, como Claude Desktop/Code.
REDCLAUDEPROXY_REQUIRE_AUTH=1
REDCLAUDEPROXY_AUTH_TOKENS=red

# Por padrao publica apenas modelos claude-red-* importados do proxy normal.
REDCLAUDEPROXY_MODEL_INCLUDE_PREFIXES=claude-red-
REDCLAUDEPROXY_MODEL_INCLUDE_ALL=0
REDCLAUDEPROXY_DEFAULT_MODEL=claude-red-devstral-medium
REDCLAUDEPROXY_MODEL_REFRESH_TTL_SECONDS=300

REDCLAUDEPROXY_DATA_DIR=/var/lib/redclaudeproxy
REDCLAUDEPROXY_CONNECT_TIMEOUT=20
REDCLAUDEPROXY_READ_TIMEOUT=360
REDCLAUDEPROXY_STREAM_CHUNK_SIZE=1
REDCLAUDEPROXY_RETRY_STATUSES=401,402,403,408,409,429,500,502,503,504
REDCLAUDEPROXY_COOLDOWN_401=3600
REDCLAUDEPROXY_COOLDOWN_402=21600
REDCLAUDEPROXY_COOLDOWN_403=300
REDCLAUDEPROXY_COOLDOWN_429=180
# O upstream aqui e o proxy normal. Um 5xx pode ser falha pontual de provider/modelo,
# entao nao deve esfriar o token interno inteiro.
REDCLAUDEPROXY_COOLDOWN_5XX=0
