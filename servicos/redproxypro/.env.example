# RED Proxy Pro
# Copie para /etc/redproxypro.env na VM e preencha as chaves reais fora do Git.

REDPROXYPRO_HOST=127.0.0.1
REDPROXYPRO_PORT=8095
REDPROXYPRO_VERCEL_BASE_URL=https://ai-gateway.vercel.sh/v1

# Formatos aceitos:
# REDPROXYPRO_KEYS="nome1:vck_xxx,nome2:vck_yyy"
# ou uma entrada por linha usando REDPROXYPRO_KEYS_FILE=/etc/redproxypro.keys
REDPROXYPRO_KEYS="nome:vck_EXEMPLO"

# Quando definido, clientes precisam enviar Authorization: Bearer <token>
# ou X-API-Key: <token>. Na RED, usamos isso para nao expor o pool em publico.
REDPROXYPRO_REQUIRE_AUTH=1
REDPROXYPRO_AUTH_TOKENS=red

REDPROXYPRO_CONNECT_TIMEOUT=20
REDPROXYPRO_READ_TIMEOUT=360
REDPROXYPRO_STREAM_CHUNK_SIZE=1
REDPROXYPRO_RETRY_STATUSES=401,403,408,409,429,500,502,503,504
REDPROXYPRO_COOLDOWN_401=3600
REDPROXYPRO_COOLDOWN_403=300
REDPROXYPRO_COOLDOWN_429=180
REDPROXYPRO_COOLDOWN_5XX=60
