RED_PROXY_HOST=127.0.0.1
RED_PROXY_PORT=8080
RED_PROXY_DATA_DIR=/var/lib/redvm-proxy
RED_PROXY_UPSTREAM=http://127.0.0.1:11434

RED_PROXY_DEFAULT_CHAT_MODEL=red/qwen3-next:80b
RED_PROXY_DEFAULT_VISION_MODEL=red/NIM - meta/llama-3.2-11b-vision-instruct
RED_PROXY_DEFAULT_IMAGE_MODEL=NIM - flux.2-klein-4b
RED_PROXY_DEFAULT_EMBEDDINGS_MODEL=
RED_PROXY_ENABLE_CAPABILITY_FALLBACK=true
RED_PROXY_PUBLIC_API_KEY_ENABLED=true
RED_PROXY_PUBLIC_API_KEY=red
RED_PROXY_RETRY_STATUSES=401,402,403,404,408,409,429,500,502,503,504
RED_PROXY_MAX_FAILOVER_KEYS=16
RED_PROXY_COOLDOWN_401=3600
RED_PROXY_COOLDOWN_402=21600
RED_PROXY_COOLDOWN_403=300
RED_PROXY_COOLDOWN_404=60
RED_PROXY_COOLDOWN_429=180
RED_PROXY_COOLDOWN_5XX=60

RED_PROXY_NVIDIA_CHAT_BASE=https://integrate.api.nvidia.com/v1
RED_PROXY_NVIDIA_GENAI_BASE=https://api.nvcf.nvidia.com/v2/nvcf
RED_PROXY_NVIDIA_CHAT_TIMEOUT_SECONDS=360
RED_PROXY_NVIDIA_CHAT_STREAM_TIMEOUT_SECONDS=360
RED_PROXY_NVIDIA_MODEL_REFRESH_ENABLED=true
RED_PROXY_NVIDIA_MODEL_REFRESH_TTL_SECONDS=3600
RED_PROXY_NVIDIA_MODEL_CACHE_FILE=/var/lib/redvm-proxy/nvidia_models_cache.json
RED_PROXY_RESPONSES_MIN_OUTPUT_TOKENS=2048
RED_PROXY_NVIDIA_API_KEY=
NVIDIA_API_KEY=

RED_PROXY_MISTRAL_CHAT_BASE=https://api.mistral.ai/v1
RED_PROXY_MISTRAL_CHAT_TIMEOUT_SECONDS=120
RED_PROXY_MISTRAL_MODEL_REFRESH_ENABLED=true
RED_PROXY_MISTRAL_MODEL_REFRESH_TTL_SECONDS=3600
RED_PROXY_MISTRAL_MODEL_CACHE_FILE=/var/lib/redvm-proxy/mistral_models_cache.json
RED_PROXY_MISTRAL_API_KEY=
MISTRAL_API_KEY=
