REDVM_DASH_PASSWORD=change-me
REDVM_SECRET=change-me-too
REDVM_DATA_DIR=/opt/redvm-dashboard/data
REDVM_HOME=/opt/redvm-dashboard
REDVM_PUBLIC_HOST=http://redsystems.ddns.net
REDVM_SHELL=/bin/bash
RED_LOCAL_TIMEZONE=America/Sao_Paulo

REDIA_URL=http://127.0.0.1:3099
REDIA_ADMIN_TOKEN=change-me

RED_PROXY_URL=http://127.0.0.1:8080
RED_PROXY_SERVICE=red-ollama-proxy
RED_PROXY_DATA_DIR=/var/lib/redvm-proxy
RED_PROXY_MODEL_CACHE_TTL=30

RED_REPO_RUNTIME_ROOT=/opt
RED_PROJECT_RUNTIME_ROOT=/opt
RED_PROJECT_SOURCES_ROOT=/srv/projects
RED_PROJECT_NGINX_ROUTES_DIR=/etc/nginx/sites-enabled
RED_PROJECT_NGINX_SERVERS_DIR=/etc/nginx/sites-available
RED_PROJECT_WEBHOOK_BASE_PATH=/hooks
RED_PROJECT_SHARED_ROUTE_PREFIX=/
RED_PROJECT_PORT_BASE=4000
RED_PROJECT_PORT_STEP=10
RED_PROJECT_HEALTH_RETRIES=8
RED_PROJECT_HEALTH_DELAY=2.5
RED_PROJECT_AI_TIMEOUT=35

RED_WHATSAPP_WEBHOOK_PATH=/hooks/whatsapp
RED_WHATSAPP_ALERT_COOLDOWN_SECONDS=120
