RED_LAB_PROXY_HOST=0.0.0.0
RED_LAB_PROXY_PORT=8090
RED_LAB_PROXY_DATA_DIR=/opt/red-proxy-lab/data
RED_LAB_PROXY_MAX_RETRIES=2
RED_LAB_PROXY_TIMEOUT_SECONDS=45
RED_LAB_PROXY_AUTODISCOVER=true

RED_LAB_GROQ_BASE_URL=https://api.groq.com/openai/v1
RED_LAB_GROQ_KEYS_FILE=/opt/red-proxy-lab/data/groq_keys.json
RED_LAB_GROQ_TIMEOUT_SECONDS=35
RED_LAB_GROQ_MODELS=openai/gpt-oss-20b,openai/gpt-oss-120b,meta-llama/llama-4-maverick-17b-128e-instruct,qwen/qwen3-32b

RED_LAB_MISTRAL_BASE_URL=https://api.mistral.ai/v1
RED_LAB_MISTRAL_KEYS_FILE=/opt/red-proxy-lab/data/mistral_keys.json
RED_LAB_MISTRAL_TIMEOUT_SECONDS=45
RED_LAB_MISTRAL_MODELS=mistral-small-latest,mistral-medium-latest,mistral-large-latest,ministral-8b-latest,ministral-3b-latest
